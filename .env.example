# .env.example

# OpenAI: Para embeddings y razonamiento
OPENAI_API_KEY=

# Anthropic: Opcional, para razonamiento complejo
ANTHROPIC_API_KEY=

# Supabase: Para la base de datos vectorial (pgvector)
SUPABASE_URL=

# Supabase Service Role Key: Para bypass de RLS en el backend
SUPABASE_SERVICE_ROLE_KEY=

# Google Ads: Integración con la API de Google Ads
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=

# Finanzas: El candado financiero estricto
MAX_DAILY_BUDGET_USD=

# NeonDB: URL de conexión a la base de datos PostgreSQL con soporte vectorial
DATABASE_URL=""
